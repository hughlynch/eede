{
  "name": "eede",
  "displayName": "eede — Earth Engine Development Environment",
  "description": "Modern development environment for Google Earth Engine with dual-language notebooks, map rendering, and asset management.",
  "version": "0.1.0",
  "publisher": "hugh-lynch",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugh-lynch/eede"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Notebooks",
    "Data Science",
    "Visualization"
  ],
  "keywords": [
    "earth-engine",
    "geospatial",
    "remote-sensing",
    "gis",
    "notebook"
  ],
  "activationEvents": [
    "onNotebook:eede-notebook",
    "onCommand:eede.openMap",
    "workspaceContains:**/*.eede"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "notebooks": [
      {
        "type": "eede-notebook",
        "displayName": "Earth Engine Notebook",
        "selector": [
          { "filenamePattern": "*.eede" }
        ]
      }
    ],
    "commands": [
      {
        "command": "eede.openMap",
        "title": "Open Map",
        "icon": "$(globe)",
        "category": "Earth Engine"
      },
      {
        "command": "eede.openInspector",
        "title": "Open Inspector",
        "icon": "$(search)",
        "category": "Earth Engine"
      },
      {
        "command": "eede.authenticate",
        "title": "Authenticate",
        "icon": "$(key)",
        "category": "Earth Engine"
      },
      {
        "command": "eede.newNotebook",
        "title": "New Notebook",
        "icon": "$(notebook)",
        "category": "Earth Engine"
      },
      {
        "command": "eede.refreshAssets",
        "title": "Refresh Assets",
        "icon": "$(refresh)",
        "category": "Earth Engine"
      },
      {
        "command": "eede.cancelTask",
        "title": "Cancel Task",
        "icon": "$(close)",
        "category": "Earth Engine"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eede",
          "title": "Earth Engine",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "eede": [
        {
          "id": "eede.assets",
          "name": "Assets"
        },
        {
          "id": "eede.tasks",
          "name": "Tasks"
        },
        {
          "id": "eede.layers",
          "name": "Map Layers"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "eede.refreshAssets",
          "when": "view == eede.assets",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "eede.cancelTask",
          "when": "view == eede.tasks && viewItem == running"
        }
      ]
    },
    "configuration": {
      "title": "Earth Engine",
      "properties": {
        "eede.projectId": {
          "type": "string",
          "default": "",
          "description": "Google Cloud project ID for Earth Engine."
        },
        "eede.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python interpreter with ee package installed."
        },
        "eede.authMethod": {
          "type": "string",
          "enum": ["gcloud", "oauth", "service-account"],
          "default": "gcloud",
          "description": "Authentication method for Earth Engine."
        },
        "eede.oauthClientId": {
          "type": "string",
          "default": "",
          "description": "OAuth 2.0 client ID (for web-hosted deployments)."
        },
        "eede.oauthClientSecret": {
          "type": "string",
          "default": "",
          "description": "OAuth 2.0 client secret (for web-hosted deployments)."
        },
        "eede.serviceAccountKeyPath": {
          "type": "string",
          "default": "",
          "description": "Path to service account key JSON (when authMethod is service-account)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "@google/earthengine": "^1.0.0"
  }
}
